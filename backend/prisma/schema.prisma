// Prisma schema — SQLite provider.
// Datasource & generator config.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// User-defined category for grouping transactions.
/// `userId` is null for global seed categories, non-null for user-specific categories.
model Category {
  id          String   @id @default(uuid())
  name        String
  description String   @default("")
  color       String
  icon        String
  userId      String?  @map("user_id")

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("categories")
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Core user account.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  passwordHash String @map("password_hash")

  transactions Transaction[]
  categories   Category[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Financial transaction (income or expense).
model Transaction {
  id          String   @id @default(uuid())
  description String
  amount      Float
  type        String   // "INCOME" | "EXPENSE"
  category    String
  date        DateTime
  isExample   Boolean  @default(false) @map("is_example")

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([date])
  @@map("transactions")
}
