// Prisma schema — SQLite provider.
// Datasource & generator config.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// User-defined category for grouping transactions.
model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  color       String
  icon        String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Core user account.
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  passwordHash String @map("password_hash")

  transactions Transaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Financial transaction (income or expense).
model Transaction {
  id          String   @id @default(uuid())
  description String
  amount      Float
  type        String   // "INCOME" | "EXPENSE"
  category    String
  date        DateTime

  user   User   @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([date])
  @@map("transactions")
}
